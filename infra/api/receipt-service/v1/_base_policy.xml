<policies>
    <inbound>
        <base />
        <set-query-parameter name="fiscal_code" exists-action="override">
            <value>@(context.Request.Headers.GetValueOrDefault("fiscal_code",""))</value>
        </set-query-parameter>
        <!-- Cache lookup only for GET /messages/{tp_id} (JSON). The PDF endpoint /messages/{tp_id}/{attachment_url} and /info are excluded -->
        <choose>
            <when condition="@(System.Text.RegularExpressions.Regex.IsMatch(context.Request.Url.Path, "/messages/[^/]+/?$"))">
                <cache-lookup-value key="@("msg-" + context.Request.Url.Path)" variable-name="cachedBody" caching-type="internal" />
                <choose>
                    <when condition="@(context.Variables.ContainsKey("cachedBody"))">
                        <return-response>
                            <set-status code="200" reason="OK" />
                            <set-header name="Content-Type" exists-action="override">
                                <value>application/json</value>
                            </set-header>
                            <set-header name="X-Cache" exists-action="override">
                                <value>HIT</value>
                            </set-header>
                            <set-body>@((string)context.Variables["cachedBody"])</set-body>
                        </return-response>
                    </when>
                </choose>
            </when>
        </choose>
    </inbound>
    <outbound>
        <base />
        <!-- Store response in the APIM internal cache only for GET /messages/{tp_id} (JSON), TTL 2 min (120s) -->
        <choose>
            <when condition="@(System.Text.RegularExpressions.Regex.IsMatch(context.Request.Url.Path, "/messages/[^/]+/?$") && context.Response.StatusCode == 200)">
                <cache-store-value key="@("msg-" + context.Request.Url.Path)" value="@(context.Response.Body.As<string>(preserveContent: true))" duration="120" caching-type="internal" />
            </when>
        </choose>
    </outbound>
    <backend>
        <base />
    </backend>
    <on-error>
        <base />
    </on-error>
</policies>
